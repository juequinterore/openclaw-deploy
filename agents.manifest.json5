// Deployment manifest for `./setup.sh --sync-agents` — see AGENTS-PLUGINS.md
// for the full contract. This is the single source of truth for
// `agents.list` in openclaw.json: agents added by hand, outside this file,
// are foreign to the sync and will make it abort (see "Foreign agents" in
// AGENTS-PLUGINS.md §5.1).
//
// The default entry below is the reference/demo package (a local path, not
// git — so a fresh clone works offline). Replace or add to it with your own
// agents, e.g.:
//
//   { source: "git@github.com:acme/openclaw-billing.git", ref: "v1.2.0" },
//
{
  // Optional global coordinator knobs — defaults shown; uncomment to override.
  // coordinator: {
  //   id: "main",
  //   name: "🧭 Front Desk",
  //   maxPingPongTurns: 0,
  //   defaultTimeoutMs: 180000,  // per-specialist "typically done within" shown to users (overridable per agent via timeoutMs)
  // },

  agents: [
    // dispatch "send": echo answers in seconds and benefits from its
    // persistent session — the worked example of the synchronous
    // request/reply mode (long-job specialists like virginia use the default
    // "spawn" background mode instead).
    { source: "examples/agents/echo-bot", ref: null, dispatch: "send" },

    // Worked example — a real, pre-existing agent repo with no
    // openclaw.agent.json5 (Model B: declare its shape inline). Sallie is a
    // lead-intake specialist whose skills are TypeScript (installed in-image
    // via npm ci — AGENTS-PLUGINS.md §7.1) and which needs HubSpot/Tavily
    // secrets from THIS deployment's .env (declared by name — §7.2). Uncomment
    // and pin a real ref to plug her in:
    //
    { source: "git@bitbucket.org:57blocks/sallie.git", ref: "chore/testing-standards-and-tests",
      id: "sallie", name: "Sallie", role: "Event lead intake, scoring, HubSpot pushes.",
      model: "anthropic/claude-sonnet-5",   // this deploy runs claude-cli, not her native gpt-5.4
      tools: { profile: "coding" },
      // Owner-confirmed fast responder (well under the 30s send window), so
      // she uses the synchronous request/reply mode and keeps conversational
      // continuity in her persistent session. If real intake runs start
      // missing the window, flip back to the default "spawn".
      dispatch: "send",
      timeoutMs: 600000,                       // "typically done within" budget quoted to users (send replies are near-instant; this bounds worst-case)

      env: {
        // Only secret the branch's skill code actually reads at runtime
        // (process.env["HUBSPOT_ACCESS_TOKEN"], shared/single-tenant — the
        // per-user HUBSPOT_ACCESS_TOKEN_<ID> routing isn't wired yet).
        required: ["HUBSPOT_ACCESS_TOKEN"],
        // Voice intake; only matters if this deployment wires Whisper.
        optional: ["OPENAI_WHISPER_API_KEY"],
      } },

    // Virginia — the worked Python example (AGENTS-DEPS-SPEC.md). Her repo was
    // restructured for the pluggable-agent contract on the branch below
    // (workspace/ subdir + root openclaw.agent.json5). Ships NO pinned lock on
    // purpose: exercises the resolve-at-sync-time path (revised D2, §3.2). Her
    // pyproject declares beautifulsoup4/pillow/playwright/pydantic/python-dotenv
    // (Python, into .python-site) and package.json declares openbrand (npm);
    // `playwright` auto-derives a chromium browser layer (§7.4), so the first
    // sync will abort with the exact Dockerfile lines to append (chromium is a
    // root/apt image layer, never installed into a workspace).
    { source: "git@bitbucket.org:57blocks/onepagerbuilder.git",
      ref: "feature/email_sub_agent",
      timeoutMs: 1500000,  // 25-minute execution budget; full research + rendering can exceed the previous 15-minute limit
      // The gateway's default thinking=adaptive let sonnet burn two ~30K-token
      // extended-thinking blocks (~17 min of wall-clock) authoring one brief
      // (measured live, StudyFetch 2026-07-17). Her workflow is script-driven;
      // "low" keeps a small reasoning budget for brief quality without the
      // multi-minute burn. Passed through as sessions_spawn's per-spawn
      // `thinking` override. This is the DEFAULT — a user can override per
      // request in chat ("… use medium thinking"), which the coordinator
      // applies to the spawn instead.
      thinking: "low",
      // Appended verbatim to every task dispatched to virginia. It both forces
      // the complete workflow and stages all user-facing files under main's
      // media-allowed workspace so Discord/Slack can attach them.
      taskHint: "Run your complete one-pager workflow. The required user-facing deliverables are the rendered PDF, the editable .editor.html, and outputs/<slug>/cold-email.md; a text-only summary is not finished. Before your final reply, copy those three files into /home/node/.openclaw/workspace/deliveries/<slug>/<render-stamp>/ using the actual slug and render stamp. Include the three copied absolute paths as separate plain MEDIA: lines and name all three files in your reply. Do not attach the plain intermediate .html.",
      },
  ],
}
